{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "esnext",
    "lib": ["DOM", "ES2020"],
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationDir": "dist/esm",
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}
