{
  "name": "use-element-dimensions",
  "description": "React hook for observing DOM element dimensions with live updates",
  "version": "2.1.3",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "browser": "dist/umd/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "keywords": [
    "react",
    "dimensions",
    "size",
    "resize",
    "hook"
  ],
  "files": [
    "dist",
    "demo.gif"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielkov/use-element-dimensions.git"
  },
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "start": "vite --open /example/test/index.html",
    "dev": "vite --open /example/simple/index.html",
    "example:simple": "vite --open /example/simple/index.html",
    "example:multiple": "vite --open /example/multiple/index.html",
    "example:test": "vite --open /example/test/index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "standard-version"
  },
  "author": "Daniel Emod Kovacs <kovacsemod@gmail.com>",
  "peerDependencies": {
    "react": ">=16.8.0 <20.0.0",
    "react-dom": ">=16.8.0 <20.0.0"
  },
  "dependencies": {
    "use-sync-external-store": "^1.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
